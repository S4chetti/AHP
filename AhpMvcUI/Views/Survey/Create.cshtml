@{
    ViewData["Title"] = "Yeni Anket Oluştur";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-10">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-primary text-white p-4">
                    <h3 class="mb-0">Yeni Anket Tasarla</h3>
                </div>
                <div class="card-body p-5">
                    <div class="mb-4">
                        <label class="form-label fw-bold">Anket Başlığı</label>
                        <input type="text" id="surveyTitle" class="form-control form-control-lg" placeholder="Örn: Müşteri Memnuniyet Anketi">
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-bold">Açıklama</label>
                        <textarea id="surveyDescription" class="form-control" rows="3" placeholder="Anketin amacı hakkında kısa bilgi..."></textarea>
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-bold">Kategori</label>
                        <select id="surveyCategory" class="form-select"></select>
                    </div>

                    <hr class="my-5" />

                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h4 class="fw-bold">Sorular</h4>
                        <button type="button" id="btnAddQuestion" class="btn btn-outline-primary">
                            <i class="bi bi-plus-circle"></i> Soru Ekle
                        </button>
                    </div>

                    <div id="questionsContainer"></div>

                    <button id="btnSaveSurvey" class="btn btn-success btn-lg w-100 mt-4 shadow">Anketi Yayınla</button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let questionCount = 0;

        $(document).ready(function () {
            loadCategories();

            $("#btnAddQuestion").click(function () {
                questionCount++;
                addQuestionBlock(questionCount);
            });

            $(document).on("change", ".question-type", function () {
                const id = $(this).data("id");
                const optionsDiv = $("#optionsContainer_" + id);
                if ($(this).val() === "multiple") {
                    optionsDiv.show();
                } else {
                    optionsDiv.hide();
                }
            });

            $(document).on("click", ".btn-add-option", function () {
                const id = $(this).data("id");
                const container = $("#optionsList_" + id);
                container.append('<div class="input-group mb-2"><input type="text" class="form-control option-input" placeholder="Seçenek metni"><button class="btn btn-outline-danger btn-remove-option" type="button">Sil</button></div>');
            });

            $(document).on("click", ".btn-remove-option", function () {
                $(this).closest(".input-group").remove();
            });

            $("#btnSaveSurvey").click(saveSurvey);
        });

        function loadCategories() {
            $.ajax({
                url: "http://localhost:5030/api/Categories",
                type: "GET",
                success: function (data) {
                    const select = $("#surveyCategory");
                    $.each(data, function (i, item) {
                        select.append(new Option(item.name, item.id));
                    });
                }
            });
        }

        function addQuestionBlock(id) {
            const html = `
                <div class="card mb-4 question-block border-start border-primary border-4 shadow-sm" data-id="${id}">
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-8 mb-3">
                                <label class="form-label small fw-bold">Soru Metni</label>
                                <input type="text" class="form-control question-text" placeholder="Sorunuzu yazın...">
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label small fw-bold">Soru Tipi</label>
                                <select class="form-select question-type" data-id="${id}">
                                    <option value="rating">Derecelendirme (1-5)</option>
                                    <option value="multiple">Çoktan Seçmeli</option>
                                </select>
                            </div>
                        </div>
                        <div id="optionsContainer_${id}" style="display:none;" class="mt-2 bg-light p-3 rounded">
                            <label class="form-label small fw-bold">Seçenekler</label>
                            <div id="optionsList_${id}"></div>
                            <button type="button" class="btn btn-sm btn-link btn-add-option" data-id="${id}">+ Seçenek Ekle</button>
                        </div>
                    </div>
                </div>`;
            $("#questionsContainer").append(html);
        }

        function saveSurvey() {
            const token = localStorage.getItem("token");
            const surveyData = {
                title: $("#surveyTitle").val(),
                description: $("#surveyDescription").val(),
                categoryId: parseInt($("#surveyCategory").val()),
                questions: []
            };

            $(".question-block").each(function () {
                const id = $(this).data("id");
                const type = $(this).find(".question-type").val();
                const question = {
                    text: $(this).find(".question-text").val(),
                    isRating: type === "rating",
                    options: []
                };

                if (type === "multiple") {
                    $(this).find(".option-input").each(function () {
                        if ($(this).val()) question.options.push($(this).val());
                    });
                }

                surveyData.questions.push(question);
            });

            $.ajax({
                url: "http://localhost:5030/api/Surveys",
                type: "POST",
                contentType: "application/json",
                headers: { "Authorization": "Bearer " + token },
                data: JSON.stringify(surveyData),
                success: function () {
                    alert("Anket başarıyla oluşturuldu!");
                    window.location.href = "/Admin/Surveys";
                }
            });
        }
    </script>
}