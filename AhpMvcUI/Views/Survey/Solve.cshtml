@{
    ViewData["Title"] = "Anketi Doldur";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow border-0 mb-4">
                <div class="card-body p-5" id="surveyContainer">
                    <div class="text-center">
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">Yükleniyor...</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let currentSurveyId = @ViewBag.SurveyId;

        $(document).ready(function () {
            var token = localStorage.getItem("token");
            if (!token) {
                alert("Anketi doldurmak için giriş yapmalısınız.");
                window.location.href = "/Auth/Login";
                return;
            }

            $.ajax({
                url: "http://localhost:5030/api/Surveys/Details/" + currentSurveyId,
                type: "GET",
                headers: { "Authorization": "Bearer " + token },
                success: function (data) {
                    renderSurvey(data);
                },
                error: function () {
                    $("#surveyContainer").html('<div class="alert alert-danger">Anket yüklenirken bir hata oluştu.</div>');
                }
            });
        });

        function renderSurvey(survey) {
            var html = '<h2 class="fw-bold text-primary mb-3">' + survey.title + '</h2>';
            html += '<p class="text-muted mb-4">' + survey.description + '</p><hr class="mb-4"/>';

            html += '<div id="questionsForm">';
            $.each(survey.questions, function (index, q) {
                html += '<div class="mb-4 question-item" data-qid="' + q.id + '">';
                html += '<h5 class="fw-bold">' + (index + 1) + '. ' + q.text + '</h5>';

                if (q.options && q.options.length > 0) {
                    html += '<div class="mt-2">';
                    $.each(q.options, function (optIndex, opt) {
                        html += '<div class="form-check form-check-inline">';
                        html += '<input class="form-check-input q-option" type="radio" name="q_' + q.id + '" value="' + opt.id + '">';
                        html += '<label class="form-check-label">' + opt.text + '</label>';
                        html += '</div>';
                    });
                    html += '</div>';
                } else {
                    html += '<div class="mt-2">';
                    html += '<textarea class="form-control q-text-response" rows="3" placeholder="Cevabınızı buraya yazın..."></textarea>';
                    html += '</div>';
                }
                html += '</div>';
            });
            html += '</div>';

            html += '<hr class="my-4"/>';
            html += '<button id="btnSubmitAnswers" class="btn btn-success btn-lg w-100">Cevapları Gönder</button>';
            html += '<div id="submitMessage" class="mt-3 text-center"></div>';

            $("#surveyContainer").html(html);

            $("#btnSubmitAnswers").click(submitAnswers);
        }

                function submitAnswers() {
            var token = localStorage.getItem("token");
            var answers = [];
            var isValid = true;

            $(".question-item").each(function () {
                var qId = $(this).data("qid");
                var selectedOption = $(this).find(".q-option:checked").val();
                var textResponse = $(this).find(".q-text-response").val();

                if (!selectedOption && (!textResponse || textResponse.trim() === "")) {
                    isValid = false;
                }

                        
                answers.push({
                QuestionId: parseInt(qId),
                OptionId: selectedOption ? parseInt(selectedOption) : null,
                TextResponse: textResponse ? textResponse.trim() : ""
            });
            });

            if (!isValid) {
                alert("Lütfen tüm soruları cevaplayın!");
                return;
            }

            $.ajax({
                url: "http://localhost:5030/api/Surveys/SubmitAnswers",
                type: "POST",
                contentType: "application/json",
                headers: { "Authorization": "Bearer " + token },
                data: JSON.stringify(answers),
                success: function () {
                    $("#submitMessage").html('<div class="alert alert-success shadow-sm">Cevaplarınız başarıyla kaydedildi! Ana sayfaya yönlendiriliyorsunuz...</div>');
                    setTimeout(function () {
                        window.location.href = "/Home/Index";
                    }, 2000);
                },
                error: function (xhr) {
                    console.log(xhr.responseText);
                    $("#submitMessage").html('<div class="alert alert-danger shadow-sm">Cevaplar gönderilirken bir hata oluştu: ' + xhr.responseText + '</div>');
                }
            });
        }
    </script>
}