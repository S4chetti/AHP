@{
    ViewData["Title"] = "Anketler";
}

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-md-8">
            <h2 class="fw-bold">Aktif Anketler</h2>
            <p class="text-muted">Katılmak istediğiniz anketi seçerek görüşlerinizi bildirebilirsiniz.</p>
        </div>
        <div class="col-md-4">
            <select id="categoryFilter" class="form-select form-select-lg shadow-sm">
                <option value="0">Tüm Kategoriler</option>
            </select>
        </div>
    </div>

    <div id="surveyList" class="row g-4">
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            loadCategories();
            loadSurveys(0);

            $("#categoryFilter").change(function () {
                loadSurveys($(this).val());
            });
        });

        function loadCategories() {
            $.ajax({
                url: "http://localhost:5030/api/Categories",
                type: "GET",
                success: function (data) {
                    var select = $("#categoryFilter");
                    $.each(data, function (i, item) {
                        select.append('<option value="' + item.id + '">' + item.name + '</option>');
                    });
                }
            });
        }

        function loadSurveys(categoryId) {
            $.ajax({
                url: "http://localhost:5030/api/Surveys",
                type: "GET",
                success: function (data) {
                    var html = "";
                    var filteredData = categoryId == 0 ? data : data.filter(x => x.categoryId == categoryId);

                    if (filteredData.length === 0) {
                        html = '<div class="col-12 text-center mt-5"><h5>Bu kategoride henüz anket bulunmuyor.</h5></div>';
                    } else {
                        $.each(filteredData, function (i, item) {
                            html += '<div class="col-md-4">';
                            html += '<div class="card h-100 shadow-sm border-0">';
                            html += '<div class="card-body p-4">';
                            html += '<span class="badge bg-soft-primary text-primary mb-2">' + (item.categoryName || "Genel") + '</span>';
                            html += '<h5 class="card-title fw-bold">' + item.title + '</h5>';
                            html += '<p class="card-text text-muted small">' + item.description.substring(0, 100) + '...</p>';
                            html += '</div>';
                            html += '<div class="card-footer bg-white border-0 p-4 pt-0">';
                            html += '<a href="/Survey/Solve/' + item.id + '" class="btn btn-primary w-100 shadow-sm">Anketi Çöz</a>';
                            html += '</div></div></div>';
                        });
                    }
                    $("#surveyList").html(html);
                }
            });
        }
    </script>
}