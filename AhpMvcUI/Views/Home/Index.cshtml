@{
    ViewData["Title"] = "Ana Sayfa - Anketler";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
        <h2 class="display-6 text-primary fw-bold">Aktif Anketler</h2>
        <a href="/Survey/Create" class="btn btn-primary btn-lg shadow-sm" id="btnNewSurvey">
            <i class="bi bi-plus-circle"></i> Yeni Anket Ekle
        </a>
    </div>

    <div class="row" id="surveyList">
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            loadSurveys();
        });

        function loadSurveys() {
            var token = localStorage.getItem("token");

            $.ajax({
                url: "http://localhost:5030/api/Surveys",
                type: "GET",
                headers: {
                    "Authorization": "Bearer " + token
                },
                success: function (data) {
                    var html = "";
                    if (data.length === 0) {
                        html = '<div class="col-12"><div class="alert alert-info">Henüz oluşturulmuş bir anket bulunmamaktadır.</div></div>';
                    } else {
                        $.each(data, function (index, survey) {
                            html += '<div class="col-md-4 mb-4">';
                            html += '<div class="card h-100 shadow-sm border-0 bg-light">';
                            html += '<div class="card-body">';
                            html += '<h5 class="card-title text-dark fw-bold">' + survey.title + '</h5>';
                            html += '<p class="card-text text-muted">' + survey.description + '</p>';
                            html += '</div>';
                            html += '<div class="card-footer bg-transparent border-top-0 pb-3">';
                            html += '<a href="/Survey/Solve/' + survey.id + '" class="btn btn-outline-primary w-100">Ankete Git</a>';
                            html += '</div>';
                            html += '</div>';
                            html += '</div>';
                        });
                    }
                    $("#surveyList").html(html);
                },
                error: function (xhr) {
                    if (xhr.status === 401) {
                        $("#surveyList").html('<div class="col-12"><div class="alert alert-warning">Anketleri görmek için sisteme giriş yapmalısınız (Token eksik).</div></div>');
                    } else {
                        $("#surveyList").html('<div class="col-12"><div class="alert alert-danger">Anketler yüklenirken bir hata oluştu. API projesinin çalıştığından emin olun.</div></div>');
                    }
                }
            });
        }
    </script>
}