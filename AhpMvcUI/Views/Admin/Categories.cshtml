@{
    ViewData["Title"] = "Kategori Yönetimi";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800">Kategori Yönetimi</h1>
    <button class="btn btn-primary shadow-sm" data-toggle="modal" data-target="#addCategoryModal">
        <i class="fas fa-plus fa-sm text-white-50"></i> Yeni Kategori Ekle
    </button>
</div>

<div class="card shadow mb-4">
    <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-primary">Sistemdeki Kategoriler</h6>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered" id="categoriesTable" width="100%" cellspacing="0">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Kategori Adı</th>
                        <th>İşlemler</th>
                    </tr>
                </thead>
                <tbody id="categoryList">
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="addCategoryModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Yeni Kategori Ekle</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label>Kategori Adı</label>
                    <input type="text" id="categoryName" class="form-control" />
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">İptal</button>
                <button type="button" class="btn btn-primary" id="btnSaveCategory">Kaydet</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            loadCategories();

            $("#btnSaveCategory").click(function () {
                var name = $("#categoryName").val();
                var token = localStorage.getItem("token");

                $.ajax({
                    url: "http://localhost:5030/api/Categories",
                    type: "POST",
                    contentType: "application/json",
                    headers: { "Authorization": "Bearer " + token },
                    data: JSON.stringify({ name: name }),
                    success: function () {
                        $("#addCategoryModal").modal('hide');
                        $("#categoryName").val('');
                        loadCategories();
                    }
                });
            });
        });

        function loadCategories() {
            var token = localStorage.getItem("token");
            $.ajax({
                url: "http://localhost:5030/api/Categories",
                type: "GET",
                headers: { "Authorization": "Bearer " + token },
                success: function (data) {
                    var html = "";
                    $.each(data, function (index, category) {
                        html += '<tr>';
                        html += '<td>' + category.id + '</td>';
                        html += '<td>' + category.name + '</td>';
                        html += '<td>';
                        html += '<button class="btn btn-danger btn-sm" onclick="deleteCategory(' + category.id + ')"><i class="fas fa-trash"></i> Sil</button>';
                        html += '</td>';
                        html += '</tr>';
                    });
                    $("#categoryList").html(html);
                }
            });
        }

        function deleteCategory(id) {
            if (confirm("Bu kategoriyi silmek istediğinize emin misiniz?")) {
                var token = localStorage.getItem("token");
                $.ajax({
                    url: "http://localhost:5030/api/Categories/" + id,
                    type: "DELETE",
                    headers: { "Authorization": "Bearer " + token },
                    success: function () {
                        loadCategories();
                    }
                });
            }
        }
    </script>
}