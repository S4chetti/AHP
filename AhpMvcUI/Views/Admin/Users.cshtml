@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Kullanıcı Yönetimi";
}

<div class="container mt-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-dark text-white">
            <h5 class="mb-0">Sistemdeki Kullanıcılar</h5>
        </div>
        <div class="card-body">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Ad Soyad</th>
                        <th>Kullanıcı Adı</th>
                        <th>Rol</th>
                        <th>İşlemler</th>
                    </tr>
                </thead>
                <tbody id="userTableBody"></tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            loadUsers();
        });

        function loadUsers() {
            var token = localStorage.getItem("token");
            $.ajax({
                url: "http://localhost:5030/api/Users",
                type: "GET",
                headers: { "Authorization": "Bearer " + token },
                success: function (data) {
                    var html = "";
                    $.each(data, function (i, user) {
                        var role = user.roles.includes("Admin") ? "Admin" : "User";
                        var btnClass = role === "Admin" ? "btn-warning" : "btn-success";
                        var nextRole = role === "Admin" ? "User" : "Admin";

                        html += "<tr>";
                        html += "<td>" + user.fullName + "</td>";
                        html += "<td>" + user.userName + "</td>";
                        html += "<td><span class='badge bg-info'>" + role + "</span></td>";
                        html += "<td>";
                        html += "<button class='btn " + btnClass + " btn-sm me-2' onclick='changeRole(\"" + user.id + "\", \"" + nextRole + "\")'>" + nextRole + " Yap</button>";
                        html += "<button class='btn btn-danger btn-sm' onclick='deleteUser(\"" + user.id + "\")'>Sil</button>";
                        html += "</td></tr>";
                    });
                    $("#userTableBody").html(html);
                }
            });
        }

        function changeRole(userId, roleName) {
            var token = localStorage.getItem("token");
            $.ajax({
                url: "http://localhost:5030/api/Users/ChangeRole?userId=" + userId + "&roleName=" + roleName,
                type: "POST",
                headers: { "Authorization": "Bearer " + token },
                success: function () {
                    loadUsers();
                }
            });
        }

        function deleteUser(id) {
            if (confirm("Kullanıcıyı silmek istediğinize emin misiniz?")) {
                var token = localStorage.getItem("token");
                $.ajax({
                    url: "http://localhost:5030/api/Users/" + id,
                    type: "DELETE",
                    headers: { "Authorization": "Bearer " + token },
                    success: function () {
                        loadUsers();
                    }
                });
            }
        }
    </script>
}