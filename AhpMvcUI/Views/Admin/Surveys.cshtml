@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Anket Yönetimi";
}

<div class="container mt-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">Tüm Anketler (Yönetici)</h5>
        </div>
        <div class="card-body">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Anket Başlığı</th>
                        <th>Oluşturulma Tarihi</th>
                        <th>İşlemler</th>
                    </tr>
                </thead>
                <tbody id="adminSurveyTableBody"></tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            loadAllSurveys();
        });

        function loadAllSurveys() {
            var token = localStorage.getItem("token");
            $.ajax({
                url: "http://localhost:5030/api/Surveys",
                type: "GET",
                headers: { "Authorization": "Bearer " + token },
                success: function (data) {
                    var html = "";
                    $.each(data, function (i, item) {
                        html += "<tr>";
                        html += "<td>" + item.title + "</td>";
                        html += "<td>" + new Date(item.createdDate).toLocaleDateString() + "</td>";
                        html += "<td>";
                        html += "<button class='btn btn-danger btn-sm' onclick='deleteSurvey(" + item.id + ")'>Sil</button>";
                        html += "</td></tr>";
                    });
                    $("#adminSurveyTableBody").html(html);
                }
            });
        }

        function deleteSurvey(id) {
            if (confirm("Bu anketi ve tüm sorularını silmek istediğinize emin misiniz?")) {
                var token = localStorage.getItem("token");
                $.ajax({
                    url: "http://localhost:5030/api/Surveys/" + id,
                    type: "DELETE",
                    headers: { "Authorization": "Bearer " + token },
                    success: function () {
                        loadAllSurveys();
                    }
                });
            }
        }
    </script>
}