@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Anket Katılımcıları";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-4">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-dark text-white">
                    <h6 class="mb-0">Katılımcı Listesi</h6>
                </div>
                <div class="list-group list-group-flush" id="participantList"></div>
            </div>
        </div>
        <div class="col-md-8">
            <div id="answersDetail" class="card shadow-sm border-0" style="display:none;">
                <div class="card-header bg-primary text-white">
                    <h6 class="mb-0" id="selectedParticipantName">Cevap Detayları</h6>
                </div>
                <div class="card-body" id="responsesContent"></div>
            </div>
            <div id="emptyState" class="text-center py-5 bg-light rounded">
                <p class="text-muted">Detayları görmek için soldan bir katılımcı seçin.</p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let allData = null;
        $(document).ready(function () {
            const surveyId = new URLSearchParams(window.location.search).get('id') || @ViewBag.SurveyId;
            const token = localStorage.getItem("token");

            $.ajax({
                url: `http://localhost:5030/api/Surveys/${surveyId}/Results`,
                type: "GET",
                headers: { "Authorization": "Bearer " + token },
                success: function (data) {
                    allData = data;
                    let html = "";
                    $.each(data.participants, function (i, p) {
                        html += `<a href="#" class="list-group-item list-group-item-action p-3" onclick="showDetail(${i})">
                            <div class="d-flex justify-content-between">
                                <span class="fw-bold">${p.userName}</span>
                                <small class="text-muted">${p.date.split(' ')[0]}</small>
                            </div>
                            <small class="text-muted">${p.email}</small>
                        </a>`;
                    });
                    $("#participantList").html(html || '<div class="p-3 text-center">Henüz katılım yok.</div>');
                }
            });
        });

        function showDetail(index) {
            const p = allData.participants[index];
            $("#emptyState").hide();
            $("#answersDetail").show();
            $("#selectedParticipantName").text(p.userName + " - " + p.date);

            let html = "";
            $.each(allData.questions, function(i, q) {
                const answer = p.responses.find(r => r.questionId === q.id);
                html += `<div class="mb-4">
                    <label class="fw-bold text-primary d-block small">${i+1}. ${q.text}</label>
                    <div class="p-3 bg-light rounded border-start border-3 border-primary mt-1">
                        ${answer ? answer.answerText : '<span class="text-muted italic">Cevaplanmamış</span>'}
                    </div>
                </div>`;
            });
            $("#responsesContent").html(html);
        }
    </script>
}