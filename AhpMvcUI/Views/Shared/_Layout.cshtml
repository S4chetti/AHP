<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AHP Portal</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark bg-dark border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" asp-area="" asp-controller="Home" asp-action="Index">AHP Anket Portalı</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-toggle="target" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-light" asp-area="" asp-controller="Home" asp-action="Index">Ana Sayfa</a>
                        </li>
                    </ul>
                    <ul class="navbar-nav" id="userMenu">
                        <li class="nav-item" id="navAdmin" style="display:none;">
                            <a class="nav-link text-warning fw-bold" href="/Admin/Index">Admin Paneli</a>
                        </li>
                        <li class="nav-item" id="navLogin">
                            <a class="nav-link text-light" href="/Auth/Login">Giriş Yap</a>
                        </li>
                        <li class="nav-item" id="navRegister">
                            <a class="nav-link text-light" href="/Auth/Register">Kayıt Ol</a>
                        </li>
                        <li class="nav-item" id="navLogout" style="display:none;">
                            <a class="nav-link text-danger" href="#" onclick="logout()">Çıkış Yap</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-5">
        <div class="container text-center py-3">
            &copy; 2026 - Anket Hazırlama Portalı
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        $(document).ready(function () {
            var token = localStorage.getItem("token");
            if (token) {
                $("#navLogin").hide();
                $("#navRegister").hide();
                $("#navLogout").show();

                try {
                    var base64Url = token.split('.')[1];
                    var base64 = base64Url.replace(/-/g, '+').replace(/_/g, '/');
                    var jsonPayload = decodeURIComponent(window.atob(base64).split('').map(function (c) {
                        return '%' + ('00' + c.charCodeAt(0).toString(16)).slice(-2);
                    }).join(''));
                    var parsedToken = JSON.parse(jsonPayload);

                    var roleClaim = parsedToken["http://schemas.microsoft.com/ws/2008/06/identity/claims/role"];
                    if (roleClaim === "Admin" || (Array.isArray(roleClaim) && roleClaim.includes("Admin"))) {
                        $("#navAdmin").show();
                    }
                } catch (e) {
                    console.error("Token parse error");
                }
            }
        });

        function logout() {
            localStorage.removeItem("token");
            window.location.href = "/Home/Index";
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>