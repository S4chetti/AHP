@{
    ViewData["Title"] = "Kayıt Ol";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow border-0">
                <div class="card-body p-5">
                    <h3 class="card-title text-center mb-4 fw-bold">Yeni Hesap Oluştur</h3>

                    <div class="mb-3">
                        <label class="form-label text-muted">Ad Soyad</label>
                        <input type="text" id="FullName" class="form-control form-control-lg" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label text-muted">Kullanıcı Adı</label>
                        <input type="text" id="UserName" class="form-control form-control-lg" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label text-muted">Email Adresi</label>
                        <input type="email" id="Email" class="form-control form-control-lg" />
                    </div>
                    <div class="mb-4">
                        <label class="form-label text-muted">Şifre</label>
                        <input type="password" id="Password" class="form-control form-control-lg" />
                    </div>
                    <button id="btnRegister" class="btn btn-success btn-lg w-100 shadow-sm">Kayıt Ol</button>
                    <div id="registerMessage" class="mt-3 text-center"></div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $("#btnRegister").click(function () {
            var data = {
                FullName: $("#FullName").val(),
                UserName: $("#UserName").val(),
                Email: $("#Email").val(),
                Password: $("#Password").val()
            };

            $.ajax({
                url: "http://localhost:5030/api/Auth/Register",
                type: "POST",
                contentType: "application/json",
                data: JSON.stringify(data),
                success: function () {
                    $("#registerMessage").html('<div class="alert alert-success shadow-sm">Kayıt başarılı! Giriş sayfasına yönlendiriliyorsunuz...</div>');
                    setTimeout(function () {
                        window.location.href = "/Auth/Login";
                    }, 2000);
                },
                error: function (xhr) {
                    var errorMsg = xhr.responseText ? xhr.responseText : "Kayıt işlemi başarısız oldu.";
                    $("#registerMessage").html('<div class="alert alert-danger shadow-sm">' + errorMsg + '</div>');
                }
            });
        });
    </script>
}