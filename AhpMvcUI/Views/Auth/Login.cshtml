@{
    ViewData["Title"] = "Giriş Yap";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow border-0">
                <div class="card-body p-5">
                    <h3 class="card-title text-center mb-4 fw-bold">Sisteme Giriş</h3>

                    <div class="mb-3">
                        <label class="form-label text-muted">Kullanıcı Adı veya E-Posta</label>
                        <input type="text" id="UserName" class="form-control form-control-lg" />
                    </div>

                    <div class="mb-4">
                        <label class="form-label text-muted">Şifre</label>
                        <input type="password" id="Password" class="form-control form-control-lg" />
                    </div>
                    <button id="btnLogin" class="btn btn-primary btn-lg w-100 shadow-sm">Giriş Yap</button>
                    <div id="loginMessage" class="mt-3 text-center"></div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $("#btnLogin").click(function () {
            var data = {
                UserName: $("#UserName").val(),
                Password: $("#Password").val()
            };

            $.ajax({
                url: "http://localhost:5030/api/Auth/Login",
                type: "POST",
                contentType: "application/json",
                data: JSON.stringify(data),
                success: function (response) {
                    localStorage.setItem("token", response.token);
                    window.location.href = "/Home/Index";
                },
                error: function (xhr) {
                    var errorMsg = xhr.responseText ? xhr.responseText : "Kullanıcı adı veya şifre hatalı!";
                    $("#loginMessage").html('<div class="alert alert-danger shadow-sm">' + errorMsg + '</div>');
                }
            });
        });
    </script>
}